# Buzz runs out of the box without an .env file (Jellyfin profile by default).
# Copy this file to .env only if you need to override one of the values below.

# Override only if your host UID/GID is not 1000.
# PUID=1000
# PGID=1000

# Cap buzz-dav memory so scan/playback pressure cannot consume the host.
# Docker may restart only buzz-dav if it exceeds this limit.
# BUZZ_DAV_MEMORY_LIMIT=2g
# Defaults to BUZZ_DAV_MEMORY_LIMIT, which allows no extra swap.
# BUZZ_DAV_MEMORY_SWAP_LIMIT=2g

# Opt into the Plex profile (currently UNTESTED). Default is Jellyfin.
# COMPOSE_PROFILES=plex

# Optional Plex container settings (only consumed when the plex profile is active).
# PLEX_VERSION=docker
# PLEX_CLAIM=
